# Hermes Enterprise — exemplo de variáveis de ambiente
# Copie para `.env` (mesma pasta do docker-compose.enterprise.yml) e preencha.
# NÃO commite o `.env` real — ele contém segredos. Este arquivo é só referência.

# ==================== Postgres dedicado do Hermes (HERMES_PG_*) ====================
# Banco operacional do agente (ana_sessions, etc.). Isolado do Cesto produção.
HERMES_PG_HOST=postgres
HERMES_PG_PORT=5432
HERMES_PG_DATABASE=hermes_enterprise
HERMES_PG_USER=hermes
HERMES_PG_PASSWORD=changeme

# Senha do serviço postgres do compose (deve casar com HERMES_PG_PASSWORD)
POSTGRES_PASSWORD=changeme

# ==================== Chaves de modelo ====================
NVIDIA_API_KEY=changeme
OPENAI_API_KEY=changeme

# ==================== Config de modelo — Admin ====================
ADMIN_MODEL_PROVIDER=changeme
ADMIN_MODEL_NAME=changeme
ADMIN_MODEL_BASE_URL=changeme
ADMIN_AGENT_NAME=changeme

# ==================== Config de modelo — Ana (atendimento) ====================
ANA_MODEL_PROVIDER=changeme
ANA_MODEL_NAME=changeme
ANA_MODEL_BASE_URL=changeme
ANA_AGENT_NAME=changeme

# ==================== API Server — Admin ====================
ADMIN_API_SERVER_ENABLED=true
ADMIN_API_SERVER_PORT=8081
ADMIN_API_SERVER_HOST=0.0.0.0
ADMIN_API_KEY=changeme

# ==================== API Server — Ana (atendimento) ====================
ANA_API_SERVER_ENABLED=true
ANA_API_SERVER_PORT=8082
ANA_API_SERVER_HOST=0.0.0.0
ANA_API_KEY=changeme

# Libera todos os usuários no gateway (true/false)
GATEWAY_ALLOW_ALL_USERS=false

# ==================== Dashboard (Admin, porta 9119) ====================
DASHBOARD_ENABLED=true
DASHBOARD_PORT=9119
DASHBOARD_HOST=0.0.0.0

# ==================== Telegram (opcional) ====================
TELEGRAM_BOT_TOKEN=changeme

# ==================== Cesto d'Amore API (resumo diário) ====================
CESTO_API_URL=https://api.cestodamore.com.br
CESTO_API_KEY=changeme
CESTO_API_EMAIL=changeme
CESTO_API_PASSWORD=changeme

# ==================== Cesto produção DB (read-only, resumo diário) ====================
CESTO_PROD_PG_HOST=changeme
CESTO_PROD_PG_PORT=54320
CESTO_PROD_PG_DATABASE=cesto_damore
CESTO_PROD_PG_USER=postgres
CESTO_PROD_PG_PASSWORD=changeme

# ==================== WaHa (WhatsApp — entrega de resumo) ====================
WAHA_API_URL=https://cesto-damore-waha.ovtvje.easypanel.host/
WAHA_API_KEY=changeme
WAHA_INSTANCE=CestoDamore
WHATSAPP_GROUP_ID=changeme
